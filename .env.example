NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=4000
WEB_PORT=6173
DATABASE_URL=file:../../data/domain-analysis.sqlite
CRAWL_CONCURRENCY=1
# 同一 query+source 已存在 running/pending 超过该毫秒数时，再次点采集会删掉旧任务并新建（默认 3 分钟）。设为 0 关闭。
CRAWL_STALE_RUNNING_MS=180000
ANALYSIS_CONCURRENCY=1
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
# Reddit 默认在应用内用 Playwright（Sources 里 Reddit engine）；无需 API Key。
# 仅当调试或环境装不了浏览器时: REDDIT_COLLECTION_MODE=public_json（纯 HTTP，易被 Reddit 拒）。
# 可选 official_api（需 REDDIT_CLIENT_ID / REDDIT_CLIENT_SECRET / REDDIT_USER_AGENT）。
# REDDIT_COLLECTION_MODE=
REDDIT_PLAYWRIGHT_HEADLESS=true
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=domain-analysis/0.1.0
X_COLLECTION_MODE=nitter_rss
X_NITTER_BASE_URL=https://nitter.net
X_BEARER_TOKEN=
