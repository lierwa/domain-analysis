# 基础服务
NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=4000
WEB_PORT=6173
DATABASE_URL=file:../../data/domain-analysis.sqlite

# AI 配置
AI_PROVIDER=openai-compatible
AI_MODEL=qwen-plus
AI_API_KEY=replace-with-your-api-key
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_INSIGHTS_MAX_ITEMS_PER_BATCH=20
AI_INSIGHTS_MAX_INPUT_TOKENS_PER_BATCH=6000
AI_INSIGHTS_MAX_EXTRACTION_BATCHES=6
# AI_INSIGHTS_MAX_CANDIDATES defaults to MAX_ITEMS_PER_BATCH * MAX_EXTRACTION_BATCHES
# AI_INSIGHTS_MAX_CANDIDATES=120
AI_INSIGHTS_MAX_CONCURRENT_BATCHES=2
AI_INSIGHTS_MAX_INSIGHTS_PER_BATCH=5
AI_INSIGHTS_TEXT_CHAR_LIMIT=800
AI_INSIGHTS_DETAIL_CHAR_LIMIT=1200
AI_INSIGHTS_MIN_TEXT_CHARS=20

# 任务并发
CRAWL_CONCURRENCY=1
ANALYSIS_CONCURRENCY=1

# Reddit 采集
REDDIT_COLLECTION_MODE=public_json_fallback

# YouTube 采集
YOUTUBE_COLLECTION_MODE=yt_dlp_transcript
PYTHON_COMMAND=python
YOUTUBE_COLLECTOR_COMMAND=python
YOUTUBE_COLLECTOR_ARGS=scripts/collectors/youtube_collector.py

# X 采集
X_COLLECTION_MODE=browser_profile
X_BROWSER_USER_DATA_DIR=storage/x-login-profile
